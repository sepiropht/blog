{
  "build": {
    "env": {
      "HUGO_VERSION": "0.133.0"
    }
  },
  "env": {
    "HUGO_RELATIVEURLS": "true"
  },
  "redirects": [
    { "source": "/posts", "destination": "/", "permanent": true },
    { "source": "/posts/", "destination": "/", "permanent": true },
    { "source": "/fr/posts", "destination": "/fr/", "permanent": true },
    { "source": "/fr/posts/", "destination": "/fr/", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/.well-known/lnurlp/sepiropht",
      "destination": "/api/lnurlp"
    },
    {
      "source": "/.well-known/nostr.json",
      "destination": "/api/nostr"
    }
  ]
}
